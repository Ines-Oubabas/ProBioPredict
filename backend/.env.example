# ------------------------------------------------------------------------------
# Django core
# ------------------------------------------------------------------------------
# IMPORTANT:
# - Do not put real production secrets in this file.
# - Each developer should copy this file to backend/.env and fill local values.
# - In production, use real environment variables managed by the platform.

DJANGO_SECRET_KEY=change-me-in-local-env
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------------------------
# PostgreSQL (local defaults)
# ------------------------------------------------------------------------------
POSTGRES_DB=probiopredict_db
POSTGRES_USER=probiopredict_user
POSTGRES_PASSWORD=your-local-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Frontend/backend cross-origin settings
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ------------------------------------------------------------------------------
# JWT settings
# ------------------------------------------------------------------------------
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=False
JWT_BLACKLIST_AFTER_ROTATION=False

# ------------------------------------------------------------------------------
# Optional security toggles
# ------------------------------------------------------------------------------
# Keep these values for local HTTP dev.
# In production, prefer True + HTTPS.
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax

# ------------------------------------------------------------------------------
# Email (prediction result by email)
# ------------------------------------------------------------------------------
# Dev mock mode (no real SMTP required):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP placeholders for future real sending:
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@probiopredict.local
SERVER_EMAIL=no-reply@probiopredict.local