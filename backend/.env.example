# ------------------------------------------------------------------------------
# Django core
# ------------------------------------------------------------------------------
# IMPORTANT:
# - Do not put real production secrets in this file.
# - Each developer should copy this file to backend/.env and fill local values.
# - In production, use real environment variables managed by the platform.

DJANGO_SECRET_KEY=change-me-in-local-env
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------------------------
# PostgreSQL (local defaults)
# ------------------------------------------------------------------------------
POSTGRES_DB=probiopredict_db
POSTGRES_USER=probiopredict_user
POSTGRES_PASSWORD=your-local-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Frontend/backend cross-origin settings
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ------------------------------------------------------------------------------
# App URLs
# ------------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://127.0.0.1:8000

# ------------------------------------------------------------------------------
# JWT settings
# ------------------------------------------------------------------------------
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=False
JWT_BLACKLIST_AFTER_ROTATION=False

# ------------------------------------------------------------------------------
# Optional security toggles
# ------------------------------------------------------------------------------
# Keep these values for local HTTP dev.
# In production, prefer True + HTTPS.
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax

# ------------------------------------------------------------------------------
# Stripe
# ------------------------------------------------------------------------------
# IMPORTANT:
# - Never expose STRIPE_SECRET_KEY in the frontend.
# - STRIPE_WEBHOOK_SECRET comes from Stripe CLI locally or from Stripe Dashboard in production.
# - STRIPE_PRICE_PRO and STRIPE_PRICE_LAB are Stripe Price IDs, not Product IDs.

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PRO=price_replace_me_pro
STRIPE_PRICE_LAB=price_replace_me_lab

# ------------------------------------------------------------------------------
# Prediction plan limits
# ------------------------------------------------------------------------------
# Free keeps the current project rule: 3 predictions maximum.
# Pro allows a higher volume for regular usage.
# Lab uses 0 to mean unlimited in backend logic.

PREDICTION_FREE_PLAN_LIMIT=3
PREDICTION_PRO_PLAN_LIMIT=100
PREDICTION_LAB_PLAN_LIMIT=0

# ------------------------------------------------------------------------------
# Email (prediction result by email)
# ------------------------------------------------------------------------------
# Dev mock mode (no real SMTP required):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP placeholders for future real sending:
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@probiopredict.local
SERVER_EMAIL=no-reply@probiopredict.local